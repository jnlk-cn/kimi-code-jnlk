{
  "manifest_version": 3,
  "name": "Ganymede Code Browser Bridge",
  "version": "0.1.0",
  "description": "Lets Ganymede Code operate explicitly approved Chrome tabs.",
  "key": "",
  "permissions": [
    "activeTab",
    "debugger",
    "nativeMessaging",
    "scripting",
    "tabGroups",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Connect Ganymede Code"
  }
}
